#!/usr/bin/env sh

# Extract Jira issue ID (e.g., RED00211-69) from the current branch name
# and prepend it to the commit message if not already present.
# If no ID is found:
#   - Terminal: shows a warning and asks for confirmation
#   - GUI editors (VS Code, Xcode, Android Studio): blocks the commit with an error
#
# NOTE: --no-verify does NOT skip prepare-commit-msg.
# To bypass this hook entirely, disable Husky:
#   PowerShell:  $env:HUSKY = "0"; git commit -m "message"
#   CMD:         set HUSKY=0 && git commit -m "message"
#   Bash/sh:     HUSKY=0 git commit -m "message"

# Skip if Husky is explicitly disabled
if [ "$HUSKY" = "0" ]; then
  exit 0
fi

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Only modify user-typed messages (not merges, squashes, etc.)
if [ "$COMMIT_SOURCE" != "" ] && [ "$COMMIT_SOURCE" != "message" ]; then
  exit 0
fi

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

# Match Jira issue ID pattern: RED<digits> optionally followed by -<digits> (e.g., RED00211, RED00211-69)
ISSUE_ID=$(echo "$BRANCH" | grep -oE 'RED[0-9]+(-[0-9]+)?' | head -1)

if [ -n "$ISSUE_ID" ]; then
  COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

  # Skip if the message already contains the issue ID
  if echo "$COMMIT_MSG" | grep -qF "$ISSUE_ID"; then
    exit 0
  fi

  # Prepend the issue ID to the commit message
  echo "$ISSUE_ID: $COMMIT_MSG" > "$COMMIT_MSG_FILE"
else
  # No Jira issue ID found in branch name
  echo ""
  echo "⚠️  WARNING: No Jira issue ID found in branch '$BRANCH'."
  echo "   Expected pattern: RED<digits> or RED<digits>-<digits> (e.g., RED00211, RED00211-69)"
  echo ""

  # Check if running in an interactive terminal
  if [ -t 0 ] 2>/dev/null; then
    # Interactive terminal: ask for confirmation
    echo "   Options:"
    echo "     y - Proceed without Jira ID"
    echo "     n - Abort commit"
    echo ""
    echo "   To rename your branch:"
    echo "     git branch -m <new-name>        (e.g., git branch -m feature/RED00211-description)"
    echo ""
    echo "   To bypass this hook entirely (--no-verify does NOT work):"
    echo "     PowerShell:  \$env:HUSKY = \"0\"; git commit -m \"message\""
    echo "     CMD:         set HUSKY=0 && git commit -m \"message\""
    echo "     Bash/sh:     HUSKY=0 git commit -m \"message\""
    echo ""
    printf "   Continue without Jira ID? [y/N]: "
    read -r REPLY < /dev/tty
    case "$REPLY" in
      [yY])
        echo "   Proceeding without Jira ID..."
        exit 0
        ;;
      *)
        echo "   Commit aborted. Rename your branch and try again."
        exit 1
        ;;
    esac
  else
    # Non-interactive (GUI editor): block the commit
    echo "   Commit blocked. To fix this:"
    echo "     1. Rename your branch: git branch -m <new-name>"
    echo "        Example: git branch -m feature/RED00211-description"
    echo "     2. Or bypass this hook (--no-verify does NOT work):"
    echo "        PowerShell:  \$env:HUSKY = \"0\"; git commit -m \"message\""
    echo "        CMD:         set HUSKY=0 && git commit -m \"message\""
    echo "        Bash/sh:     HUSKY=0 git commit -m \"message\""
    echo ""
    exit 1
  fi
fi
